		


		BIEN AQUI LAS JOLLITAS PARA PODER ELIMINAR EL RUIDO, OSEA LOS COMANDOS DUPLICADOS, BIEN EMPECERMOS: 
		
		#sort:
			ESTE COMANDO SIRVE PARA CUANDO DECIDAS QUE QUIERES ORDENAR UN ARCHIVO GENERALMENTE DE LA A-Z, PERO ANTES DE ESTO VAN LOS NUMEROS DEL 0-9,
			ESTE COMANDO ES MUY UTIL PARA COMBINARLO CON EL COMANDO QUE ESTA DESPÚES "uniq" YA QUE ESTE COMANDO SOLO SIRVE PARA CUANDO LOS DUPLICADOS
			SE ENCUENTRAN JUNTOS, POR LO QUE SI HAY MUCHOS ARCHIVOS DUPLICADOS, CON EL COMANDO "sort" ANTES DE "uniq" Y UNIENDOLAS CON UN | SE	
			COMPLEMENTAN MUY BIEN, PERO SUPONGAMOS QUE NO QUIERES ELIMINAR TODAS LAS PALABRAS DUPLICADAS, SINO QUE QUIERAS DEJAR UNA DE TODAS LAS
			DUPLICADAS, BIEN ENTONCES AQUI ENTRAN LAS FLAGS PARA SORT QUE DE TODO MODOS SON MUY UTILES TANTO PARA SOLO BUSCAR LOS NO REPETIDOS, COMO LOS
			QUE SE REPITEN Y ORDENARLOS PARA QUE SEA MÁS COMODO SU ESCANEO
		  #EJEMPLO:
			# -u:           
			     SIRVE PARA LEER UNA UNICA PALABRA DE CADA UNA QUE EXISTA, YA SEA DUPLICADA O YA SEA UNICA SOLO LE UNA DE TODAS LAS QUE EXISTAN
			# -d:
			     D DE DUPLICADA xd, BIEN AHORA POR OTRO LADO, ESTE COMANDO TE ENSEÑA SOLO LOS ARCHIVOS DUPLICADOS PERO NO TE ENSEÑA UNO DE CADA
			     PALABRA DUPLICADA, SINO QUE TE ENSEÑA CADA PALABRA DUPLICADA QUE EXITSE POR LO QUE NO SUELE SER TAN UTIL
			# -n: 
			     SORT POR DETERMINADO ORDENA DEL 0 AL 9 MAXIMO, POR LO QUE UN 2 SERA MAYOR A 10, -n YA NO CUENTA UN SOLO DIGITO LEE CADENAS
			# -r - f:
			     R ORDENA EN REVERSA. MIENTRAS QUE -F IGNORA SI EL COMANDO QUE BUSCAS NO LO ESCRIBISTE CON LAS MAYUSCULAS O LAS MINUSCULAS DEL ORIGINAL
		
		#uniq:
			ESTE COMANDO ES MÁS PODEROSO QUE EL ANTERIOR, BORRA LAS PALABRAS DUPLICADAS, PERO SOLO LAS PALABRAS QUE SE ENCUENTREN JUNTAS,
			YA SEA AL COSTADO O ABAJO O ARRIBA, POR ESO SE SUELE COMPLEMENTAR CON SORT YA QUE SORT LAS ORDENA Y UNIQ CUENTA UNIO DE CADA PALABRA
			ES LO MISMO QUE sort -d, CUANDO NO TIENE NINGUNA FLAG Y QUEDA ASI "sort "archivo" | uniq = sort -u" SELECCIONA UNA PALABRA DE TODO
			
			# -u:
			     ELIMINA TODAS LAS PALABRAS JUNTAS DUPLICADAS, COMPLEMENTADO CON SORT ELIMINA TODA LINEA DUPLICADA DEJANDO SOLO LAS NO DUPLICADAS
			# -c:
			     LE OTORGA UN NÚMERO IGUAL AL NÚMERO DE COPIAS QUE TENGA X PALABRA, PERO RECUERDA SOLO LAS QUE ESTEN UNIDAS SINO LEERA TODAS
			     COMO 1 EJEMPLAR POR MÁS QUE ESTE DUPLICADO.
			# -d:
			     TE ENSEÑA LAS LINEAS DUPLICADAS SOLO 1 VEZ IGNORANDO LAS UNICAS

			
